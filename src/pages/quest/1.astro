  <!-- 成功モーダル（初期は非表示）-->
  <dialog id="success-modal" class="fixed inset-0 m-auto z-50" aria-labelledby="success-heading">
    <div class="bg-white rounded-md shadow-2xl max-w-lg w-full p-8 text-center">
