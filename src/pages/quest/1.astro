  <script>
    // クエスト内のメニュー開閉
    const menuBtn = document.getElementById("menu-btn");
    const mainMenu = document.getElementById("main-menu");

    menuBtn?.addEventListener("click", () => {
      const isExpanded = menuBtn.getAttribute("aria-expanded") === "true";

      mainMenu?.classList.toggle("hidden");
      menuBtn.setAttribute("aria-expanded", String(!isExpanded));
    });

    // クエスト完了
    let completed = false;
    let isKeyboardUser = false;

    document.addEventListener("keydown", (e) => {
      if (e.key === "Tab" || e.key === "Enter" || e.key === " ") {
        isKeyboardUser = true;
      }
    });

    document.addEventListener("pointerdown", () => {
      isKeyboardUser = false;
    });

    (window as any).completeQuest = function () {
      if (completed) return;
      completed = true;

      const isKeyboard = isKeyboardUser && document.activeElement?.id === "accessible-btn";

      const modal = document.getElementById("success-modal");
      const methodEl = document.getElementById("success-method");
      if (modal instanceof HTMLDialogElement && methodEl) {
        methodEl.innerHTML = isKeyboard
          ? `<p class="text-green-800 font-semibold">キーボードで達成しました！</p>
           <p class="mt-1">キーボードで操作可能なクエスト完了ボタンを探し出しましたね！</p>`
          : `<p class="text-orange-800 font-semibold">マウスで達成しました。</p>
           <p class="mt-1">次はぜひキーボードだけで再挑戦してみましょう。</p>`;
        modal.showModal();
        document.getElementById("success-heading")?.focus();
      }
    };

    // ダイアログを閉じるのと、解説セクションの表示
    (window as any).closeSuccessModal = function () {
      const modal = document.getElementById("success-modal");
      const explanation = document.getElementById("explanation");
      const explanationHeading = document.getElementById("explanation-heading");
      if (modal instanceof HTMLDialogElement) {
        modal.close();
      }
      if (explanation) {
        explanation.classList.remove("hidden");
        explanationHeading?.focus();
      }
    };
  </script>
