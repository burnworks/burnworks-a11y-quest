---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const { title = "アクセシビリティに問題があるウェブコンテンツの不便さを体験できるサイト" } = Astro.props;
const { description = "WCAG の特定の達成基準を意図的に満たさないウェブコンテンツを体験することで、アクセシビリティに問題があるウェブコンテンツの不便さを体験できるサイト" } = Astro.props;
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : rawBase + "/";
---

<!doctype html>
<html lang="ja" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href={`${base}favicon.ico`} />

    <meta name="description" content={description} />
    <title>{title} | by burnworks</title>
  </head>
  <body class="flex flex-col min-h-screen bg-gray-50 text-gray-900 font-sans">
    <header class="flex items-center py-6 px-4 bg-gray-900 text-white">
      <h1 class="font-bold text-lg w-full text-center">
        {title}
      </h1>
      <div class="mr-auto shrink-0 w-12 flex items-center justify-end">
        <a class="w-8 h-8 rounded-full text-white" href="https://github.com/burnworks/burnworks-a11y-quest" target="_blank">
          <span class="w-full h-full" aria-hidden="true">
            <svg fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path
                fill-rule="evenodd"
                d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                clip-rule="evenodd"></path>
            </svg>
          </span>
          <span class="sr-only">GitHub (burnworks/burnworks-a11y-quest)</span>
        </a>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="mt-auto text-center py-10 px-4 bg-gray-50 text-gray-600">
      <address class="not-italic">
        <small class="text-sm">by <a class="underline hover:no-underline" href="https://twitter.com/burnworks" target="_blank">@burnworks</a></small>
      </address>
    </footer>
  </body>
</html>
